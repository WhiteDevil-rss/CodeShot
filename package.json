{
  "name": "codeshot-pro-vsc",
  "displayName": "CodeShot Pro",
  "description": "Instantly generate visually appealing code screenshots directly from VS Code.",
  "publisher": "mrwhitedevil",
  "author": {
    "name": "Rajput Shivam Singh (Mr.WhiteDevil)"
  },
  "version": "1.0.5",
  "icon": "icon.png",
  "engines": {
    "vscode": "^1.85.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/WhiteDevil-rss/CodeShot.git"
  },
  "categories": [
    "Snippets"
  ],
  "activationEvents": [],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "codeshot.capture",
        "title": "CodeShot: Capture Screenshot"
      }
    ],
    "menus": {
      "editor/context": [
        {
          "command": "codeshot.capture",
          "group": "navigation",
          "when": "editorHasSelection"
        }
      ]
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint src --ext ts",
    "test": "node ./out/test/runTest.js"
  },
  "devDependencies": {
    "@types/vscode": "^1.85.0",
    "@types/glob": "^8.1.0",
    "@types/mocha": "^10.0.6",
    "@types/node": "18.x",
    "@typescript-eslint/eslint-plugin": "^6.15.0",
    "@typescript-eslint/parser": "^6.15.0",
    "eslint": "^8.56.0",
    "glob": "^10.3.10",
    "mocha": "^10.2.0",
    "typescript": "^5.3.3",
    "@vscode/test-electron": "^2.3.8"
  }
}